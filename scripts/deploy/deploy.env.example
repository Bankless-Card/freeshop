# Copy to deploy.env (gitignored) and fill in. deploy.sh reads this and pushes it to the
# server, where remote.sh generates the two .env.production files from it.

# ——— target ———
SERVER=root@203.0.113.10          # ssh target (a fresh Ubuntu 22.04/24.04 box works)
DOMAIN=launcher.example.com       # DNS A record must point at the server (Caddy provisions TLS)

# ——— chain ———
CHAIN_ID=11155111                                            # Sepolia
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY        # server-side (indexer); keep private
PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com   # browser-visible (launcher frontend)
FACTORY_ADDRESS=0x...             # from the forge deploy
START_BLOCK=                      # block the factory was deployed in
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238      # Sepolia USDC

# ——— secrets (leave blank to auto-generate on first deploy; they are then written back here) ———
DB_PASSWORD=
SESSION_SECRET=

# ——— optional ———
TEMPLATE_REPO_URL=                # NEXT_PUBLIC_TEMPLATE_REPO_URL, once the template repo exists
