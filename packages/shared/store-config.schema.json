{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freeshop.dev/store-config.schema.json",
  "title": "freeshop store.config.json",
  "description": "Configuration for a self-hosted freeshop storefront. Generated by the Launcher; product copy and images are safe to edit by hand. Mirrors parseStoreConfig in @freeshop/shared.",
  "type": "object",
  "required": ["version", "chainId", "storeAddress", "product", "payment", "fulfillment"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "chainId": { "type": "integer", "minimum": 1 },
    "rpcUrl": {
      "type": "string",
      "format": "uri",
      "description": "Optional RPC override. Must never be a secret — this file is public."
    },
    "storeAddress": { "$ref": "#/$defs/address" },
    "product": {
      "type": "object",
      "required": ["name", "description", "images"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      }
    },
    "payment": {
      "type": "object",
      "required": ["token", "symbol", "decimals", "price"],
      "additionalProperties": false,
      "properties": {
        "token": {
          "$ref": "#/$defs/address",
          "description": "0x0000000000000000000000000000000000000000 for native ETH, else the store's ERC-20."
        },
        "symbol": { "type": "string", "minLength": 1 },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 36 },
        "price": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Price in base units (wei for ETH, 6-decimal units for USDC). Display hint only; the contract is authoritative."
        }
      }
    },
    "fulfillment": {
      "type": "object",
      "required": ["fields"],
      "additionalProperties": false,
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "label", "type", "required"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "type": { "enum": ["text", "email", "textarea"] },
              "required": { "type": "boolean" },
              "placeholder": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
  }
}
