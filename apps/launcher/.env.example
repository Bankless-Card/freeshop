# ——— public (baked into the client bundle; never secrets) ———
NEXT_PUBLIC_CHAIN_ID=31337
# Optional RPC override (defaults to the chain's public RPC; anvil default for 31337)
# NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# The StorefrontFactory this launcher deploys through (required for the wizard)
NEXT_PUBLIC_FACTORY_ADDRESS=
# Enables the USDC payment option when set (Sepolia: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238)
# NEXT_PUBLIC_USDC_ADDRESS=
# Public storefront template repo, once extracted
# NEXT_PUBLIC_TEMPLATE_REPO_URL=

# ——— server-only ———
# Ponder indexer base URL (apps/indexer); powers dashboard analytics/orders
# PONDER_URL=http://localhost:42069
# Required in production, >= 32 chars (session cookie encryption)
# SESSION_SECRET=
# Postgres connection; omit in dev to use embedded PGlite under .data/
# DATABASE_URL=postgres://user:pass@host:5432/freeshop
