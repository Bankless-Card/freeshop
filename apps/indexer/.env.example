# Chain to index (defaults match local anvil)
INDEXER_CHAIN_ID=31337
INDEXER_RPC_URL=http://127.0.0.1:8545
# The StorefrontFactory to watch (required); its StoreDeployed events register stores automatically
FACTORY_ADDRESS=
# Block the factory was deployed at (0 is fine for anvil; set it on Sepolia/mainnet to skip empty history)
START_BLOCK=0
# Production (`ponder start`) needs Postgres; `ponder dev` uses embedded PGlite under .ponder/
# DATABASE_URL=postgres://user:pass@host:5432/freeshop_indexer
